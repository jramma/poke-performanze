generator client {
  provider = "prisma-client-js"
  output   = "../app/lib/db/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String            @id @default(cuid())
  username       String            @unique
  email          String            @unique
  password       String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  level          Int               @default(1)
  experience     Int               @default(0)
  pokeballs      Int               @default(6)
  maxPokeballs   Int               @default(6)
  lastGameDate   DateTime?
  dailyPokemonId Int?
  dailyAttempts  Int               @default(0)
  caughtToday    Boolean           @default(false)
  currentStreak  Int               @default(0)
  maxStreak      Int               @default(0)
  totalCatches   Int               @default(0)
  caughtPokemon  CaughtPokemon[]
  dailyLogs      DailyLog[]
  gameSessions   GameSession[]
  dailyPokemon   Pokemon?          @relation("DailyPokemon", fields: [dailyPokemonId], references: [id])
  achievements   UserAchievement[]

  @@index([email])
  @@index([username])
}

model Pokemon {
  id             Int             @id
  name           String          @unique
  sprite         String
  spriteShiny    String?
  types          String[]
  height         Int
  weight         Int
  baseExperience Int
  isLegendary    Boolean         @default(false)
  captureRate    Int?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  caughtBy       CaughtPokemon[]
  dailyLogs      DailyLog[]
  gameSessions   GameSession[]
  dailyForUsers  User[]          @relation("DailyPokemon")

  @@index([name])
  @@index([isLegendary])
}

model CaughtPokemon {
  id         String   @id @default(cuid())
  userId     String
  pokemonId  Int
  caughtAt   DateTime @default(now())
  critical   Boolean  @default(false)
  experience Int      @default(100)
  pokemon    Pokemon  @relation(fields: [pokemonId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, pokemonId])
  @@index([userId])
  @@index([pokemonId])
  @@index([caughtAt])
}

model GameSession {
  id            String    @id @default(cuid())
  userId        String
  pokemonId     Int
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  attempts      Int       @default(0)
  pokeballsUsed Int       @default(0)
  success       Boolean   @default(false)
  pokemon       Pokemon   @relation(fields: [pokemonId], references: [id])
  user          User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([startedAt])
}

model DailyLog {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime @default(now())
  pokemonId     Int
  attempts      Int      @default(0)
  caught        Boolean  @default(false)
  pokeballsLeft Int      @default(0)
  pokemon       Pokemon  @relation(fields: [pokemonId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model Achievement {
  id          String            @id @default(cuid())
  name        String            @unique
  description String
  icon        String
  condition   String
  reward      Json
  unlockedBy  UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  @@unique([userId, achievementId])
}

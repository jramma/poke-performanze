generator client {
  provider = "prisma-client-js"
  output   = "../app/lib/db/generated"
}

datasource db {
  provider = "postgresql" // o "sqlite" para desarrollo local
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  email         String   @unique
  password      String   // Para cuando implementemos auth
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Progreso del juego
  level         Int      @default(1)
  experience    Int      @default(0)
  pokeballs     Int      @default(6) // Pokeballs actuales
  maxPokeballs  Int      @default(6) // Máximo de pokeballs (mejorable)
  
  // Estadísticas diarias
  lastGameDate  DateTime?
  dailyPokemonId Int?
  dailyAttempts Int      @default(0)
  caughtToday   Boolean  @default(false)
  
  dailyPokemon  Pokemon? @relation("DailyPokemon", fields: [dailyPokemonId], references: [id])
  
  // Rachas y logros
  currentStreak Int      @default(0)
  maxStreak     Int      @default(0)
  totalCatches  Int      @default(0)
  
  // Relaciones
  caughtPokemon  CaughtPokemon[]
  gameSessions   GameSession[]
  dailyLogs      DailyLog[]
  achievements   UserAchievement[]
  
  @@index([email])
  @@index([username])
}

model Pokemon {
  id              Int      @id
  name            String   @unique
  sprite          String
  spriteShiny     String?
  types           String[] // Array de tipos
  height          Int
  weight          Int
  baseExperience  Int
  isLegendary     Boolean  @default(false)
  captureRate     Int?     // Ratio de captura original del juego
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relaciones
  caughtBy        CaughtPokemon[]
  dailyForUsers   User[]     @relation("DailyPokemon")
  gameSessions    GameSession[]
  dailyLogs       DailyLog[]
  
  @@index([name])
  @@index([isLegendary])
}

model CaughtPokemon {
  id        String   @id @default(cuid())
  userId    String
  pokemonId Int
  caughtAt  DateTime @default(now())
  critical  Boolean  @default(false)
  experience Int     @default(100)
  
  // Relaciones
  user      User     @relation(fields: [userId], references: [id])
  pokemon   Pokemon  @relation(fields: [pokemonId], references: [id])
  
  @@unique([userId, pokemonId])
  @@index([userId])
  @@index([pokemonId])
  @@index([caughtAt])
}

model GameSession {
  id            String   @id @default(cuid())
  userId        String
  pokemonId     Int
  startedAt     DateTime @default(now())
  endedAt       DateTime?
  attempts      Int      @default(0)
  pokeballsUsed Int      @default(0)
  success       Boolean  @default(false)
  
  // Relaciones
  user          User     @relation(fields: [userId], references: [id])
  pokemon       Pokemon  @relation(fields: [pokemonId], references: [id])
  
  @@index([userId])
  @@index([startedAt])
}

model DailyLog {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime @default(now())
  pokemonId     Int
  attempts      Int      @default(0)
  caught        Boolean  @default(false)
  pokeballsLeft Int      @default(0)
  
  // Relaciones
  user          User     @relation(fields: [userId], references: [id])
  pokemon       Pokemon  @relation(fields: [pokemonId], references: [id])
  
  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model Achievement {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  icon        String
  condition   String   // JSON con condiciones
  reward      Json     // JSON con recompensas
  
  // Relaciones
  unlockedBy  UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())
  
  user          User     @relation(fields: [userId], references: [id])
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  
  @@unique([userId, achievementId])
}